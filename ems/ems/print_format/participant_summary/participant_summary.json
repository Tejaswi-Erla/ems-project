 "font_size": 14,
 "html": "<div style=\"padding:20px;\">\r\n    <h2 style=\"text-align:center;\">Participant Summary</h2>\r\n\r\n    <p><b>Name:</b> {{ doc.name }}</p>\r\n    <p><b>Email:</b> {{ doc.email }}</p>\r\n    <p><b>Phone:</b> {{ doc.phone }}</p>\r\n\r\n    <hr>\r\n\r\n    <h3>Registered Events</h3>\r\n\r\n    <table border=\"1\" width=\"100%\" cellspacing=\"0\" cellpadding=\"5\">\r\n        <tr>\r\n            <th>Event</th>\r\n            <th>Date</th>\r\n            <th>Venue</th>\r\n        </tr>\r\n\r\n        {% set registrations = frappe.get_all(\"Registration\",\r\n            filters={\"participant\": doc.name},\r\n            fields=[\"event\"]\r\n        ) %}\r\n\r\n        {% for reg in registrations %}\r\n        {% set event_doc = frappe.get_doc(\"Events\", reg.event) %}\r\n        <tr>\r\n            <td>{{ event_doc.event_name or reg.event }}</td>\r\n            <td>{{ event_doc.event_date }}</td>\r\n            <td>{{ event_doc.venue }}</td>\r\n        </tr>\r\n        {% endfor %}\r\n\r\n    </table>\r\n</div>",
